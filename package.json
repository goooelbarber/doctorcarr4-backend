{
  "name": "backend",
  "version": "1.0.0",
  "description": "Doctor Car Backend - Node.js + Express + MongoDB + Socket.IO",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "cmd /c \"taskkill /IM node.exe /F >nul 2>&1 & nodemon --signal SIGTERM --legacy-watch --watch . --ext js,json server.js\""
  },
  "keywords": [
    "express",
    "socket.io",
    "doctor-car",
    "backend",
    "api"
  ],
  "author": "Youssef Albrbyr",
  "license": "MIT",
  "engines": {
    "node": "18.x"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "firebase-admin": "^13.6.0",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.20.1",
    "multer": "^2.1.0",
    "openai": "^6.25.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}